# Copy this file to .env.local and paste your own project values.
# Never commit .env or .env.local.

VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Shopify keys are used only as Supabase Edge Function secrets.
# Add them with:
# npm run shopify:secret -- SHOPIFY_STORE_DOMAIN=your-store.myshopify.com SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-token
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-shopify-storefront-token
